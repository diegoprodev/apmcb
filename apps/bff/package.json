    "otplib": "^13.4.1",
    "pdf-lib": "^1.17.1",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "web-push": "^3.6.7",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/qrcode": "^1.5.6",
    "typescript": "^5.8.0"
