# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Iron Session — must be at least 32 characters
SESSION_SECRET=your-session-secret-min-32-characters

# App
PORT=3001
NODE_ENV=development
WEB_URL=http://localhost:3000
CORS_ORIGINS=

# Rate limiting por IP — middleware/rate-limit.ts só confia em X-Real-IP/
# X-Forwarded-For quando NODE_ENV!==production OU esta flag é "true". Em
# produção, só marque "true" depois de confirmar que o nginx/proxy na frente
# SEMPRE sobrescreve esses headers com o IP real da conexão (ex:
# `proxy_set_header X-Real-IP $remote_addr;`) — nunca repassando valor
# vindo do cliente, senão um atacante pode falsificar o header e burlar o
# rate limit. Incidente real 2026-07-15: variável ausente em produção fez
# getClientIp() cair no fallback "proxy-headers-untrusted" — TODOS os
# clientes compartilhavam o mesmo bucket de rate limit, e uma sessão de
# testes E2E intensa esgotou a cota para todo mundo, inclusive login real.
RATE_LIMIT_TRUST_PROXY_HEADERS=false

# VAPID — Web Push notifications (generate with: node scripts/gen-vapid.js)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@apmcb.pmpb.online

# Internal secret shared with Next.js API routes for push broadcast endpoint
INTERNAL_API_SECRET=your-internal-secret-min-32-chars

# TOTP — AES-256-GCM encryption key for secrets stored in totp_secrets table
# Generate: openssl rand -hex 32
# OBRIGATÓRIO em produção (NODE_ENV=production). Ausente → secrets são armazenados como plaintext.
# Se definida: novos secrets são salvos como "v1:<iv>:<ciphertext>:<tag>" (Base64).
# CRÍTICO: nunca altere esta chave após existirem secrets criptografados no banco.
# Alterar a chave torna todos os secrets existentes inválidos (erro TOTP_SECRET_INVALID → 500).
TOTP_ENCRYPTION_KEY=
