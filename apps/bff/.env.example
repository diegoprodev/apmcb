# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Iron Session — must be at least 32 characters
SESSION_SECRET=your-session-secret-min-32-characters

# App
PORT=3001
NODE_ENV=development
WEB_URL=http://localhost:3000
CORS_ORIGINS=

# VAPID — Web Push notifications (generate with: node scripts/gen-vapid.js)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@apmcb.pmpb.online

# Internal secret shared with Next.js API routes for push broadcast endpoint
INTERNAL_API_SECRET=your-internal-secret-min-32-chars
