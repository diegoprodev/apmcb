# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Iron Session — must be at least 32 characters
SESSION_SECRET=your-session-secret-min-32-characters

# App
PORT=3001
NODE_ENV=development
WEB_URL=http://localhost:3000
CORS_ORIGINS=

# Rate limiting por IP — middleware/rate-limit.ts só confia em X-Real-IP/
# X-Forwarded-For quando NODE_ENV!==production OU esta flag é "true". Em
# produção, só marque "true" depois de confirmar que o nginx/proxy na frente
# SEMPRE sobrescreve esses headers com o IP real da conexão (ex:
# `proxy_set_header X-Real-IP $remote_addr;`) — nunca repassando valor
# vindo do cliente, senão um atacante pode falsificar o header e burlar o
# rate limit. Incidente real 2026-07-15: variável ausente em produção fez
# getClientIp() cair no fallback "proxy-headers-untrusted" — TODOS os
# clientes compartilhavam o mesmo bucket de rate limit, e uma sessão de
# testes E2E intensa esgotou a cota para todo mundo, inclusive login real.
RATE_LIMIT_TRUST_PROXY_HEADERS=false

# VAPID — Web Push notifications (generate with: node scripts/gen-vapid.js)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@apmcb.pmpb.online

# Internal secret shared with Next.js API routes for push broadcast endpoint
INTERNAL_API_SECRET=your-internal-secret-min-32-chars

# TOTP — AES-256-GCM encryption key for secrets stored in totp_secrets table
# Generate: openssl rand -hex 32
# OBRIGATÓRIO em produção (NODE_ENV=production). Ausente → secrets são armazenados como plaintext.
# Se definida: novos secrets são salvos como "v1:<iv>:<ciphertext>:<tag>" (Base64).
# CRÍTICO: nunca altere esta chave após existirem secrets criptografados no banco.
# Alterar a chave torna todos os secrets existentes inválidos (erro TOTP_SECRET_INVALID → 500).
TOTP_ENCRYPTION_KEY=

# Biometric Bridge Phase 1B — bridge Windows real (device-auth Ed25519 +
# pareamento por código one-time). Ver
# docs/superpowers/specs/2026-07-14-biometric-bridge-phase1b-windows-bridge-mvp-design.md

# HMAC-SHA256 pepper para hashear o pairing_code antes de salvar em
# biometric_pairing_codes.code_hash — o código nunca é armazenado em texto
# puro. Generate: openssl rand -hex 32. OBRIGATÓRIO — sem ela, todo
# pareamento falha fechado (POST /api/biometric/pairing-codes retorna 503).
BIOMETRIC_PAIRING_CODE_PEPPER=

# TTL do código de pareamento one-time (segundos). Default 600 (10 min).
BIOMETRIC_BRIDGE_PAIRING_CODE_TTL_SECONDS=600

# Tolerância de relógio para o timestamp assinado no device-auth do bridge
# (X-Bridge-Timestamp). Default 60s.
BIOMETRIC_BRIDGE_CLOCK_SKEW_SECONDS=60

# Página de resultados de GET /api/biometric-bridge/templates/sync. Default 500.
BIOMETRIC_TEMPLATE_SYNC_PAGE_SIZE=500

# Bucket de rate limit dedicado para /api/biometric-bridge/*, chaveado por
# X-Bridge-Device-Id (não IP) — separado do bucket "biometric" (30/min por
# IP) já usado pelo console browser-facing /reserva/biometria, que estouraria
# com o polling contínuo do bridge (challenges/next + heartbeat + template
# sync). Defaults: 120 requisições por device a cada 60s.
BIOMETRIC_BRIDGE_RATE_LIMIT_MAX=120
BIOMETRIC_BRIDGE_RATE_LIMIT_WINDOW_SECONDS=60

# Qualidade mínima (0-100) aceita em POST /api/biometric-bridge/challenges/:id/enrollment.
# Default 70. (Alias legado aceito: BIOMETRIC_MIN_ENROLLMENT_QUALITY.)
BIOMETRIC_ENROLLMENT_MIN_QUALITY=70

# Tamanho máximo (bytes) do template biométrico aceito em enrollment. Default 262144 (256KB).
BIOMETRIC_TEMPLATE_MAX_BYTES=262144

# Score mínimo (0-1) de match biométrico aceito em proof submit. Default 0.92.
BIOMETRIC_MIN_SCORE=0.92

# Exige liveness (anti-spoof) na proof biométrica. Default false — aceitável
# no MVP se o SDK/hardware não expuser LFD de forma confiável (risco residual
# documentado no DoD da Phase 1B). Nota Fase 1C: esta mesma política agora
# também governa record_biometric_enrollment (RPC), não só /proof — ver
# CRÍTICO da spec docs/superpowers/specs/2026-07-21-biometric-bridge-
# phase1c-client-design.md.
BIOMETRIC_REQUIRE_LIVENESS=false

# Chave mestra pra derivar (HKDF-SHA256, determinístico, nunca armazenado
# por-tenant) a chave AES-256-GCM que decifra os templates biométricos
# sincronizados via /templates/sync — GET /api/biometric-bridge/tenant-key.
# MESMO NÍVEL DE CRITICIDADE que TOTP_ENCRYPTION_KEY: nesta fase (1C),
# NUNCA alterar depois de usado em produção — rotacionar quebra a
# decifragem de TODOS os tenants simultaneamente (sem versionamento ativo
# nesta fase; ver spec seção 3.2). Obrigatória em produção (Fail Fast).
# Gerar com: openssl rand -base64 48
BIOMETRIC_TEMPLATE_MASTER_KEY=
